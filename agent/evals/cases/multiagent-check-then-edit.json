{
  "id": "check-then-edit",
  "suites": ["smoke", "multiagent"],
  "description": "Main agent reads the document then proposes a validated edit for mixed spelling variants.",
  "autopilot_policy": "suggest_only",
  "document_path": "methods.md",
  "document": "# Methods\n\nThe colour model is fixed. We use a consistent color throughout.\n",
  "instruction": "Fix the mixed spelling in the methods section.",
  "model_script": [
    { "tools": [{ "name": "read_document", "input": { "path": "methods.md" } }] },
    {
      "tools": [
        {
          "name": "propose_edits",
          "input": {
            "path": "methods.md",
            "title": "Consistent spelling",
            "summary": "Normalize 'colour' to 'color'.",
            "edits": [
              { "kind": "replace", "old_text": "colour", "new_text": "color" }
            ]
          }
        }
      ]
    },
    { "text": "Proposed a spelling fix after reading the document." }
  ],
  "expect": {
    "must_call": ["read_document", "propose_edits"],
    "must_create_group": true,
    "valid_anchor_count": "all",
    "must_not_emit": ["document/patch"],
    "document_unchanged": true
  }
}
